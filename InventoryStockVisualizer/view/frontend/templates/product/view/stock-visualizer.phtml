/** @var \Magento\InventoryStockVisualizer\Block\Product\StockVisualizer $block */
/** @var \Magento\Framework\Escaper $escaper */

$pin = '<svg class="sv-pin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"'
    . ' stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">'
    . '<path d="M12 21s-7-6.5-7-11a7 7 0 0 1 14 0c0 4.5-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg>';
?>
<?php if ($block->isEnabled()): ?>
    <?php $isLevel = $block->isLevelMode(); ?>
    <?php $isOnDemand = !$isLevel && $block->isOnDemand(); ?>
    <div class="stock-visualizer sva <?= $isLevel ? 'sv-mode-level' : 'sv-mode-quantity' ?>"
        <?php if (!$isLevel): ?>
            data-mage-init='<?= $escaper->escapeHtmlAttr($block->getWidgetConfig()) ?>'
        <?php endif; ?>>
        <div class="sva-head">
            <span class="sva-title"><?= $escaper->escapeHtml($block->getPanelTitle()) ?></span>
            <?php if ($isLevel): ?>
                <?php $aggregateLevel = $block->getAggregateLevel(); ?>
                <span class="sv-status <?= $escaper->escapeHtmlAttr($block->levelClass($aggregateLevel)) ?>">
                    <span class="sv-dot" aria-hidden="true"></span>
                    <span class="sv-word"><?= $escaper->escapeHtml($block->levelLabel($aggregateLevel)) ?></span>
                </span>
            <?php else: ?>
                <?php $status = $block->getQuantityStatusLevel(); ?>
                <span class="sv-status <?= $escaper->escapeHtmlAttr($block->levelClass($status)) ?>" data-sv-status>
                    <span class="sv-dot" aria-hidden="true"></span>
                    <span class="sv-word"><?= $escaper->escapeHtml($block->levelLabel($status)) ?></span>
                    <span class="sv-count" data-sv-agg<?= $isOnDemand ? ' style="display: none"' : '' ?>>
                        <?php if (!$isOnDemand): ?><span class="sv-skel" aria-hidden="true"></span><?php endif; ?>
                    </span>
                </span>
            <?php endif; ?>
        </div>

        <?php if ($block->isPerSource()): ?>
            <ul class="sva-body sv-sources"<?= $isOnDemand ? ' style="display: none"' : '' ?>>
                <?php if ($isLevel): ?>
                    <?php foreach ($block->getLevelSources() as $row): ?>
                        <?php $level = $row['level']; ?>
                        <li class="sv-src <?= $escaper->escapeHtmlAttr($block->levelClass($level)) ?>">
                            <div class="sv-src-top">
                                <?php if ($block->showSourceLabels()): ?>
                                    <span class="sv-name">
                                        <?= /* @noEscape */ $pin ?>
                                        <?= $escaper->escapeHtml($row['name']) ?>
                                    </span>
                                <?php endif; ?>
                                <span class="sv-lvl"><?= $escaper->escapeHtml($block->levelLabel($level)) ?></span>
                            </div>
                            <span class="sv-meter"><i style="width: <?= (int) $block->levelFill($level) ?>%"></i></span>
                        </li>
                    <?php endforeach; ?>
                <?php else: ?>
                    <?php foreach ($block->getScaffoldSources() as $row): ?>
                        <li class="sv-src" data-sv-source="<?= $escaper->escapeHtmlAttr($row['code']) ?>">
                            <div class="sv-src-top">
                                <?php if ($block->showSourceLabels()): ?>
                                    <span class="sv-name">
                                        <?= /* @noEscape */ $pin ?>
                                        <?= $escaper->escapeHtml($row['name']) ?>
                                    </span>
                                <?php endif; ?>
                                <span class="sv-val" data-sv-value>
                                    <span class="sv-skel" aria-hidden="true"></span>
                                </span>
                            </div>
                            <span class="sv-meter"><i data-sv-meter style="width: 0"></i></span>
                        </li>
                    <?php endforeach; ?>
                    <li class="sv-src sv-empty-note sv-collapsed" data-sv-empty>
                        <span class="sv-name"><?= $escaper->escapeHtml(__('No availability by source')) ?></span>
                    </li>
                <?php endif; ?>
            </ul>
        <?php endif; ?>

        <?php if ($isOnDemand): ?>
            <button type="button" class="action stock-visualizer-cta" data-sv-cta>
                <?= $escaper->escapeHtml(__('Check availability')) ?>
            </button>
        <?php endif; ?>
    </div>
<?php endif; ?>
